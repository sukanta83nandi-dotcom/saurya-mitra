rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collection: Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUserProfile(incoming())
        && incoming().uid == request.auth.uid;
        
      allow update: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().uid == existing().uid // Immutable UID
        && (
          // Action: Update Profile Info
          incoming().diff(existing()).affectedKeys().hasOnly([
            'uid', 'displayName', 'lastBillData', 'solarPreferences', 'updatedAt', 
            'formSubmitted', 'googleFormSubmitted', 'partnerOnboardingCompleted',
            'orgName', 'employeeStrength', 'email', 'contactNo', 'state', 'district', 'pinCode', 'sheetUserId'
          ])
        );

      match /reports/{reportId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReport(incoming());
        allow delete: if isOwner(userId);
      }

      match /warranties/{warrantyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWarranty(incoming());
        allow delete: if isOwner(userId);
      }
    }

    // --- Collection: Feedback ---
    match /feedback/{feedbackId} {
      allow create: if isSignedIn() 
        && isValidFeedback(incoming())
        && incoming().userId == request.auth.uid;
      // Admin only read could be added here
    }

    // --- Collection: Leads ---
    match /leads/{leadId} {
      allow create: if isSignedIn()
        && isValidLead(incoming());
    }

    // --- Validation Helpers ---
    function isValidWarranty(data) {
      return data.keys().hasAll(['createdAt', 'vendorName', 'customerName', 'panelBrand', 'invoiceNo', 'warrantyCardNo'])
        && data.createdAt == request.time;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['createdAt', 'billData', 'systemSize', 'cost'])
        && data.createdAt == request.time;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['userId', 'name', 'contact', 'systemType', 'serverTimestamp'])
        && data.userId == request.auth.uid
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() <= 256
        && data.contact is string && data.contact.size() <= 128
        && data.systemType is string && data.systemType.size() <= 64
        && data.serverTimestamp == request.time;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'feedback', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.feedback is string && data.feedback.size() <= 2000
        && data.createdAt == request.time;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'updatedAt'])
        && data.uid is string && data.uid.size() <= 128
        && (data.get('email', null) == null || (data.email is string && data.email.size() <= 256))
        && (data.get('phoneNumber', null) == null || (data.phoneNumber is string && data.phoneNumber.size() <= 32))
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128)
        && (data.get('formSubmitted', false) is bool)
        && (data.get('googleFormSubmitted', false) is bool)
        && (data.get('partnerOnboardingCompleted', false) is bool)
        && (data.get('orgName', '') is string && data.get('orgName', '').size() <= 256)
        && (data.get('employeeStrength', '') is string && data.get('employeeStrength', '').size() <= 64)
        && (data.get('contactNo', '') is string && data.get('contactNo', '').size() <= 32)
        && (data.get('state', '') is string && data.get('state', '').size() <= 128)
        && (data.get('district', '') is string && data.get('district', '').size() <= 128)
        && (data.get('pinCode', '') is string && data.get('pinCode', '').size() <= 32)
        && (data.get('sheetUserId', '') is string && data.get('sheetUserId', '').size() <= 128)
        && (data.get('updatedAt', '') is string) 
        && isValidBillData(data.get('lastBillData', null))
        && isValidSolarPreferences(data.get('solarPreferences', null));
    }

    function isValidBillData(bill) {
      return bill == null || (
        bill.keys().hasAll(['connectedLoad', 'unitsConsumed'])
        && bill.connectedLoad is number
        && bill.unitsConsumed is number
      );
    }

    function isValidSolarPreferences(pref) {
      return pref == null || (
        pref.keys().hasAll(['systemType', 'roofSize'])
        && pref.systemType in ['on-grid', 'off-grid', 'hybrid']
        && pref.roofSize in ['small', 'medium', 'large']
      );
    }
  }
}
