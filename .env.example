# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ELEVENLABS_API_KEY: Required for ElevenLabs Conversational AI voice session authentication.
# Without this key, an agent that requires authorization will disconnect after the greeting.
ELEVENLABS_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Partner Onboarding Sheet Integration
# Set this to your Google Apps Script Web App URL
VITE_SHEETS_WEBHOOK_URL=""
# Option A: Use a Google Apps Script Webhook (Recommended - No Keys Needed)
FEEDBACK_WEBHOOK_URL=""

# Option B: Use Google Service Account (Secure, but requires private key)
GOOGLE_SCRIPT_URL=
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""

# SMTP settings for sending onboarding thank you emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Saurya Mitra <no-reply@sauryamitra.com>"
